# =============================================================================
# SkySend — Environment Variables Template
# =============================================================================
#
# Copy this file to .env.local and fill in your real values before running
# the app.  NEVER commit .env.local — it is gitignored.
#
# Sections:
#   1. Clerk (Authentication)       — required
#   2. Supabase (Database)          — required
#   3. Stripe (Payments)            — required
#   4. App URL                      — optional, defaults to localhost:3000
#   5. Map provider                 — optional, maps degrade without keys
#   6. Email (Resend)               — optional, emails skipped if absent
#   7. AI / LLM (OpenRouter/OpenAI/Tavily) — optional, heuristics used as fallback
#   8. External data (Overpass)     — optional, has public default
#
# Read src/lib/env.ts  for client-side (NEXT_PUBLIC_*) variable docs.
# Read src/lib/env.server.ts for server-side secret variable docs.
# =============================================================================


# ─── 1. Clerk (Authentication) ───────────────────────────────────────────────
# Clerk dashboard: https://dashboard.clerk.com → API Keys

# Publishable key — safe to expose in the browser bundle.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_with_your_clerk_publishable_key

# Secret key — server only; NEVER put this in NEXT_PUBLIC_* or client code.
CLERK_SECRET_KEY=sk_test_replace_with_your_clerk_secret_key

# Clerk route paths (optional — the defaults below match the app's routing).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/auth/continue
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/auth/continue


# ─── 2. Supabase (Database) ──────────────────────────────────────────────────
# Supabase dashboard: Project Settings → API

# Project URL — safe to expose in the browser bundle.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anonymous (public) key — RLS policies control what anon users can access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace_with_anon_key

# Service-role key — bypasses RLS; server only; NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.replace_with_service_role_key


# ─── 3. Stripe (Payments) ────────────────────────────────────────────────────
# Stripe dashboard: https://dashboard.stripe.com → Developers → API keys
# Use pk_test_* / sk_test_* for development, pk_live_* / sk_live_* for production.

# Publishable key — safe to expose; used by Stripe.js Elements in the browser.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_with_your_stripe_publishable_key

# Secret key — server only; grants full Stripe API access.
STRIPE_SECRET_KEY=sk_test_replace_with_your_stripe_secret_key

# Webhook signing secret — verifies events from Stripe's webhook endpoint.
# Obtain from Stripe dashboard → Developers → Webhooks → your endpoint.
# Optional in dev (signature verification is skipped when empty).
STRIPE_WEBHOOK_SECRET=whsec_replace_with_your_stripe_webhook_secret


# ─── 4. App URL ──────────────────────────────────────────────────────────────
# Canonical base URL used for absolute links (OG images, emails, redirects).
# Defaults to http://localhost:3000 in development.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Six-digit code required to open /admin/settings. Access lasts 3 minutes.
ADMIN_SETTINGS_ACCESS_CODE=123456


# ─── 5. Map Provider ─────────────────────────────────────────────────────────
# Provider name controls which tile/geocoding backend is used.
# Currently: "geoapify"
NEXT_PUBLIC_MAP_PROVIDER=geoapify

# Geoapify API key — used client-side for map rendering and geocoding.
# Obtain from https://myprojects.geoapify.com → API Keys.
# Leave empty to disable map tiles (app still works, maps degrade).
NEXT_PUBLIC_GEOAPIFY_API_KEY=replace_with_your_geoapify_api_key

# Geoapify map style URL (optional — uses SDK default when empty).
# NEXT_PUBLIC_GEOAPIFY_MAP_STYLE=https://maps.geoapify.com/v1/styles/osm-carto/style.json?apiKey=...

# Override tile URL (optional — used for self-hosted tile servers).
# NEXT_PUBLIC_MAP_TILE_URL=https://tiles.yourhost.com/{z}/{x}/{y}.png

# Override geocoding URL (optional — used for self-hosted geocoders).
# NEXT_PUBLIC_MAP_GEOCODING_URL=https://geocode.yourhost.com/v1/search

# Override map public token (optional — for providers that need a separate token).
# NEXT_PUBLIC_MAP_PUBLIC_TOKEN=

# Server-side map API key (optional — for server-rendered geocoding / proxied requests).
# MAP_PROVIDER_SECRET_KEY=replace_with_server_side_map_key

# Overpass API endpoint for OSM data queries.
# Defaults to the public instance; override with a self-hosted instance in production.
OVERPASS_API_URL=https://overpass-api.de/api/interpreter


# ─── 6. Email (Resend) ───────────────────────────────────────────────────────
# Used to send transactional emails (order confirmations, delivery updates).
# Obtain from https://resend.com → API Keys.
# Without these, email sending is silently skipped.

RESEND_API_KEY=re_replace_with_your_resend_api_key
RESEND_FROM_EMAIL=SkySend Support <support@skysend.ro>
RESEND_INBOUND_DOMAIN=nexaev.resend.app
RESEND_WEBHOOK_SECRET=whsec_replace_with_your_resend_webhook_secret

# Private Cloudflare R2 bucket used by support, parcel evaluations and inbound
# email attachments. These credentials are server-only.
CLOUDFLARE_R2_ACCOUNT_ID=replace_with_cloudflare_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=replace_with_r2_access_key_id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=replace_with_r2_secret_access_key
CLOUDFLARE_R2_BUCKET=skysend-private-uploads
CLOUDFLARE_R2_ENDPOINT=https://replace_with_account_id.r2.cloudflarestorage.com

# Cloudflare R2 storytelling media. These credentials are used only by the
# local release script and must never be configured as NEXT_PUBLIC variables.
CLOUDFLARE_R2_MEDIA_ACCESS_KEY_ID=replace_with_media_r2_access_key_id
CLOUDFLARE_R2_MEDIA_SECRET_ACCESS_KEY=replace_with_media_r2_secret_access_key
CLOUDFLARE_R2_MEDIA_PUBLIC_BUCKET=skysend-public-media
CLOUDFLARE_R2_MEDIA_SOURCE_BUCKET=skysend-media-source
CLOUDFLARE_R2_MEDIA_ENDPOINT=https://replace_with_account_id.r2.cloudflarestorage.com
CLOUDFLARE_R2_MEDIA_PUBLIC_URL=https://media.skysend.website

# Optional local/preview override. An empty value deliberately uses same-origin
# media; when omitted, the tracked release points at media.skysend.website.
NEXT_PUBLIC_STORYTELLING_MEDIA_BASE_URL=

# Internal staff access. Create one Clerk organization named "SkySend Internal"
# using the standard org:admin/org:member roles. Cloudflare Access protects
# /admin/* and /api/admin/* and its group contains exact staff emails.
CLERK_INTERNAL_ORGANIZATION_ID=org_replace_with_internal_org_id
STAFF_ACCESS_ENFORCEMENT=strict
CLOUDFLARE_ACCESS_ENFORCED=true
CLOUDFLARE_ACCESS_ACCOUNT_ID=replace_with_cloudflare_account_id
CLOUDFLARE_ACCESS_GROUP_ID=replace_with_access_group_id
CLOUDFLARE_ACCESS_API_TOKEN=replace_with_least_privilege_access_groups_token
CLOUDFLARE_ACCESS_TEAM_DOMAIN=https://replace_with_team_name.cloudflareaccess.com
CLOUDFLARE_ACCESS_AUD=replace_with_application_audience_tag

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ACCESS_TOTP_ENCRYPTION_KEY=replace_with_32_byte_base64_key
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_RECOVERY_CODE_PEPPER=replace_with_random_hex_pepper

# Used by Vercel Cron to authorize the daily physical deletion of expired files.
CRON_SECRET=replace_with_a_long_random_secret


# ─── 7. AI / LLM (Parcel Estimator) ─────────────────────────────────────────
# AI backend for parcel-weight / dimension estimation.
# Without API keys the estimator falls back to deterministic heuristics.

# Provider: "openrouter" (default) or "openai"
AI_PROVIDER=openrouter

# OpenRouter — routes requests to many LLM providers via a single API.
# Obtain from https://openrouter.ai → API Keys.
OPENROUTER_API_KEY=sk-or-v1-replace_with_your_openrouter_api_key
OPENROUTER_MODEL=anthropic/claude-3-haiku
# Optional dedicated model for Parcel AI image understanding. Defaults to
# openrouter/free, which must expose text+image input in OpenRouter Models API.
OPENROUTER_PARCEL_VISION_MODEL=openrouter/free
# Optional: a separate lightweight model for the SkySend help assistant.
# Falls back to OPENROUTER_MODEL when omitted.
OPENROUTER_ASSISTANT_MODEL=
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=SkySend

# Optional product catalog credentials. Open Food Facts needs only a descriptive
# User-Agent; Open Icecat credentials are issued after free catalog registration.
OPEN_FOOD_FACTS_USER_AGENT=SkySend Parcel AI/1.0 (https://skysend.website)
ICECAT_USERNAME=
ICECAT_PASSWORD=

# OpenAI — direct OpenAI API access (used when AI_PROVIDER=openai).
# Obtain from https://platform.openai.com → API keys.
# OPENAI_API_KEY=sk-replace_with_your_openai_api_key

# Tavily — product lookup web pentru estimări de colet mai precise.
# Optional. Dacă lipsește sau requestul eșuează, estimatorul folosește
# doar profilul semantic local + OpenRouter (fără crash, fără surse web).
# Obtain from https://tavily.com → API Keys.
TAVILY_API_KEY=tvly-replace_with_your_tavily_api_key
