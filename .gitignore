# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# Storytelling media is versioned in Cloudflare R2. Keep local source and
# generated assets available to the processing scripts without committing them.
/public/assets/storytelling/
/public/assets/story telling poze si video/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next-dev-lan*.log

.env.local
.env*.local
.env
node_modules
.next
.vercel
*.tsbuildinfo

.vercel

# supabase — CLI/dashboard artefacts that shouldn't be versioned.
# Migrations and seed.sql remain committed and are the source of truth.
supabase/.env
supabase/.env.*
supabase/.branches/
supabase/.temp/
supabase/temp/
